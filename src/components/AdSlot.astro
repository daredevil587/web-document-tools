---
export interface Props {
  slot?: string;
}
const { slot: slotName = 'banner' } = Astro.props;
---

<!-- AdSlot placeholder — replace with real AdSense unit before launch -->
<!-- The div is kept for easy ad injection, hidden until real ads are configured -->
<div class="ad-slot" data-ad-slot={slotName} style="display:none;">
  Ad · {slotName}
</div>
